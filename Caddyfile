# ============================================================
# Caddy 配置文件
# 极简笔记 - HTTP 反向代理 / PHP-FPM
# 配合 frp 等反向代理工具实现 HTTPS
# ============================================================

{
    admin off
    log {
        output stdout
    }
    http_port 8080
    # 禁用自动 HTTPS（Caddy 默认会给非 localhost 的域名申请 TLS 证书）
    # 我们的场景：Nginx/frp 在外面做反代，这里只提供 HTTP
    auto_https off
}

:8080 {
    root * /var/www/html
    encode gzip

    # PHP 文件走 FastCGI（必须单独匹配，避免被 try_files 当静态文件返回）
    @php_files path *.php
    php_fastcgi @php_files localhost:9000

    # 静态文件长期缓存
    @static {
        not {
            path *.php
        }
    }
    header @static Cache-Control "public, max-age=5184000"
    try_files {path} {path}/ /index.php?{query}
}
